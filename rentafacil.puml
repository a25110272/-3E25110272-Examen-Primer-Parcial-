@startuml

class Placa
class Marca

class Modelo
class Anio

class Precio
class Cilindrada

class Carga
class Id
class Nombre
class Dni

class Telefono

class Codigo
class Fecha
class Costo
class Estado

class Registro

class Disponibilidad

class Sistema {
  - Alquiler alquileres[0..*]
  - Cliente clientes[0..*]
  - Vehiculo vehiculos[0..*]
  + Cliente : registrarcliente(Cliente)
  + Vehiculo : regsitarvehiculo(Vehiculo)
+ Alquiler: Rentar(Cliente,Vehiculo[1..3])
  + Estado : Terminarrenta(Codigo)
  + Disponibilidad : Checar(Placa)
 +Registro : Registrar(Alquiler)
  
}
class Vehiculo {
  - Placa placa[1]
  - Marca marca[1]
  - Modelo modelo[1]
  - Anio aniofabr[1]
  - Precio precioxdia[1]
  + Disponibilidad : VerificarDisponibilidad()
}
class Auto 
class Moto {
  - Cilindrada cc[1]
}
class Camioneta {
  - Carga carga[1]
}
class Cliente {
  - Id id[1]
  - Nombre nombre[1]
  - Dni dni[1]
  - Telefono telefono[1]
}

class Alquiler {
  - Codigo codigo[1]
  - Fecha fechas[2] 
  - Costo costoalq[1]
  - Estado estado[1]
  + Costo : costototal()
}
Auto --|> Vehiculo
Moto --|> Vehiculo
Camioneta --|> Vehiculo

Sistema"1" *-- "0..*" Cliente
Sistema"1" *-- "0..*" Vehiculo
 Sistema "1" *-- "0..*" Alquiler
Alquiler "1" o-- "1" Cliente
Alquiler "1" o-- "1..3" Vehiculo
Vehiculo "1" *-- "1" Placa
Vehiculo "1" *-- "1" Marca
Vehiculo "1" *-- "1" Modelo
    Vehiculo "1" *-- "1" Anio
Vehiculo "1" *-- "1" Precio

Moto "1" *-- "1" Cilindrada
Camioneta "1" *-- "1" Carga

Cliente "1" *-- "1" Id
Cliente "1" *-- "1" Nombre
Cliente "1" *-- "1" Dni
Cliente "1" *-- "1" Telefono

Alquiler "1" *-- "1" Codigo
Alquiler "1" *-- "2" Fecha
Alquiler "1" *-- "1" Costo
Alquiler "1" *-- "1" Estado
Sistema "1" *-- "0..*" Registro
Registro "1" o-- "1" Alquiler






@enduml